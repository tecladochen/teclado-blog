# =========================
# 版本
# 建议明确指定版本号，不要用 latest，方便回滚
# =========================
DIFY_VERSION=1.14.2
DIFY_SANDBOX_VERSION=0.2.15
DIFY_PLUGIN_DAEMON_VERSION=0.6.1-local

# 全局 locale，避免容器里出现 setlocale 警告
LANG=C.UTF-8
LC_ALL=C.UTF-8
PYTHONIOENCODING=utf-8

# =========================
# 基础
# DEPLOY_ENV：部署环境标识，影响一些默认行为
# SECRET_KEY：Dify 用于签名 session、token 的密钥，必须随机生成
# INIT_PASSWORD：首次启动初始化管理员账号用的密码
# =========================
DEPLOY_ENV=PRODUCTION
LOG_LEVEL=INFO
MIGRATION_ENABLED=true
SECRET_KEY=<请用 openssl rand -base64 42 生成一串随机字符串>
INIT_PASSWORD=<给初始管理员账号设置的密码>

# =========================
# 对外访问地址
# 没配 HTTPS 前可以先写 http://你的域名 或 http://ECS公网IP
# 上 HTTPS 后统一改成 https://你的域名
# INTERNAL_FILES_URL：容器之间互调用的内网地址，保持不变即可
# =========================
CONSOLE_API_URL=https://dify.example.com
CONSOLE_WEB_URL=https://dify.example.com
SERVICE_API_URL=https://dify.example.com
APP_API_URL=https://dify.example.com
APP_WEB_URL=https://dify.example.com
FILES_URL=https://dify.example.com
INTERNAL_FILES_URL=http://api:5001
TRIGGER_URL=https://dify.example.com

WEB_API_CORS_ALLOW_ORIGINS=*
CONSOLE_CORS_ALLOW_ORIGINS=*

ENABLE_COLLABORATION_MODE=false
NEXT_PUBLIC_SOCKET_URL=

# =========================
# PostgreSQL：阿里云 RDS
# DB_DATABASE：Dify 主库
# DB_PLUGIN_DATABASE：插件守护进程使用的库
# SQLALCHEMY_POOL_*：连接池参数，生产环境建议调高
# =========================
DB_TYPE=postgresql
DB_USERNAME=dify_user
DB_PASSWORD=<RDS 数据库密码>
DB_HOST=<RDS 内网地址，例如 pgm-xxxxxxxx.pg.rds.aliyuncs.com>
DB_PORT=5432
DB_DATABASE=dify
DB_PLUGIN_DATABASE=dify_plugin
DB_SSL_MODE=disable

SQLALCHEMY_POOL_SIZE=30
SQLALCHEMY_MAX_OVERFLOW=10
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_PRE_PING=true

# =========================
# Redis：阿里云 Redis
# REDIS_DB=0 给 Dify 自身缓存
# CELERY_BROKER_URL 走 /1，给 Celery 队列
# 注意：密码如果包含 @ : / # ? % 等特殊字符，要 URL 编码
# =========================
REDIS_HOST=<Redis 内网地址，例如 r-xxxxxxxx.redis.rds.aliyuncs.com>
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=<Redis 密码>
REDIS_DB=0
REDIS_USE_SSL=false
REDIS_SOCKET_TIMEOUT=5.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_RETRY_RETRIES=3
REDIS_HEALTH_CHECK_INTERVAL=30

CELERY_BROKER_URL=redis://:<URL编码后的Redis密码>@<Redis内网地址>:6379/1
CELERY_BACKEND=redis
BROKER_USE_SSL=false

# =========================
# 向量库：外部 Qdrant
# VECTOR_INDEX_NAME_PREFIX：collection 名前缀，方便区分环境
# =========================
VECTOR_STORE=qdrant
VECTOR_INDEX_NAME_PREFIX=prod_
QDRANT_URL=http://<Qdrant ECS 内网 IP>:6333
QDRANT_API_KEY=<Qdrant 的 api-key>
QDRANT_CLIENT_TIMEOUT=30
QDRANT_GRPC_ENABLED=false
QDRANT_GRPC_PORT=6334
QDRANT_REPLICATION_FACTOR=1

# =========================
# 文件存储：阿里云 OSS
# ALIYUN_OSS_ENDPOINT：用 internal 内网域名，省流量也更安全
# ALIYUN_OSS_PATH：所有文件统一放在这个前缀下
# =========================
STORAGE_TYPE=aliyun-oss
ALIYUN_OSS_BUCKET_NAME=<你的 OSS Bucket 名>
ALIYUN_OSS_ACCESS_KEY=<AccessKey ID>
ALIYUN_OSS_SECRET_KEY=<AccessKey Secret>
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou-internal.aliyuncs.com
ALIYUN_OSS_REGION=cn-hangzhou
ALIYUN_OSS_AUTH_VERSION=v4
ALIYUN_OSS_PATH=dify-prod

# =========================
# Sandbox：代码执行沙箱
# SANDBOX_API_KEY：API 与 Sandbox 之间互相验证的密钥，随机生成即可
# CODE_EXECUTION_API_KEY 必须与 SANDBOX_API_KEY 保持一致
# =========================
SANDBOX_API_KEY=<随机字符串，例如 openssl rand -base64 42>
SANDBOX_GIN_MODE=release
SANDBOX_WORKER_TIMEOUT=15
SANDBOX_ENABLE_NETWORK=true
SANDBOX_PORT=8194

CODE_EXECUTION_ENDPOINT=http://sandbox:8194
CODE_EXECUTION_API_KEY=<与 SANDBOX_API_KEY 保持一致>
CODE_EXECUTION_SSL_VERIFY=True

# =========================
# SSRF Proxy：限制 Sandbox 网络访问范围，防止内网穿透
# =========================
SSRF_HTTP_PORT=3128
SSRF_REVERSE_PROXY_PORT=8194
SSRF_SANDBOX_HOST=sandbox
SANDBOX_HTTP_PROXY=http://ssrf_proxy:3128
SANDBOX_HTTPS_PROXY=http://ssrf_proxy:3128
SSRF_PROXY_HTTP_URL=http://ssrf_proxy:3128
SSRF_PROXY_HTTPS_URL=http://ssrf_proxy:3128

# =========================
# Plugin Daemon：插件安装、执行、升级
# PLUGIN_DAEMON_KEY / PLUGIN_DIFY_INNER_API_KEY：服务间通信的密钥
# PIP_MIRROR_URL：让插件安装走阿里云镜像，速度快很多
# PLUGIN_IGNORE_UV_LOCK=true：避免 uv 死盯 lock 文件，配合镜像源重新解析依赖
# =========================
PLUGIN_DAEMON_PORT=5002
PLUGIN_DAEMON_URL=http://plugin_daemon:5002
PLUGIN_DAEMON_KEY=<随机字符串>
PLUGIN_DIFY_INNER_API_KEY=<随机字符串，与上面同一类>
PLUGIN_DIFY_INNER_API_URL=http://api:5001

PLUGIN_MAX_PACKAGE_SIZE=52428800
PLUGIN_DAEMON_TIMEOUT=1200
PLUGIN_PYTHON_ENV_INIT_TIMEOUT=600
PLUGIN_MAX_EXECUTION_TIMEOUT=1200

FORCE_VERIFYING_SIGNATURE=true
MARKETPLACE_ENABLED=true
MARKETPLACE_API_URL=https://marketplace.dify.ai
MARKETPLACE_URL=https://marketplace.dify.ai

PIP_MIRROR_URL=https://mirrors.aliyun.com/pypi/simple/
PLUGIN_IGNORE_UV_LOCK=true
PYTHON_COMPILE_ALL_EXTRA_ARGS=-x \.venv

# 插件文件也放 OSS，避免本地盘无限膨胀
PLUGIN_STORAGE_TYPE=aliyun_oss
PLUGIN_STORAGE_OSS_BUCKET=<你的 OSS Bucket 名>
PLUGIN_WORKING_PATH=/app/storage/cwd
PLUGIN_INSTALLED_PATH=plugin
PLUGIN_PACKAGE_CACHE_PATH=plugin_packages
PLUGIN_MEDIA_CACHE_PATH=assets

PLUGIN_ALIYUN_OSS_REGION=cn-hangzhou
PLUGIN_ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou-internal.aliyuncs.com
PLUGIN_ALIYUN_OSS_ACCESS_KEY_ID=<AccessKey ID>
PLUGIN_ALIYUN_OSS_ACCESS_KEY_SECRET=<AccessKey Secret>
PLUGIN_ALIYUN_OSS_AUTH_VERSION=v4
PLUGIN_ALIYUN_OSS_PATH=dify-prod/plugin

# =========================
# Mail / SMTP
# 用户邀请、密码找回、邮件通知都走这里
# =========================
MAIL_TYPE=smtp
MAIL_DEFAULT_SEND_FROM=Dify <no-reply@example.com>

SMTP_SERVER=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_USERNAME=no-reply@example.com
SMTP_PASSWORD=<SMTP 授权密码>
SMTP_USE_TLS=true
SMTP_OPPORTUNISTIC_TLS=false
SMTP_LOCAL_HOSTNAME=example.com

# =========================
# Nginx
# NGINX_SERVER_NAME：你的访问域名
# NGINX_SSL_CERT_FILENAME / KEY_FILENAME：证书文件名，放在 nginx/ssl/ 下
# =========================
NGINX_SERVER_NAME=dify.example.com
NGINX_HTTPS_ENABLED=true
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_CLIENT_MAX_BODY_SIZE=100M
NGINX_PROXY_READ_TIMEOUT=3600s
NGINX_PROXY_SEND_TIMEOUT=3600s
EXPOSE_NGINX_PORT=80
EXPOSE_NGINX_SSL_PORT=443
NGINX_SOCKET_IO_UPSTREAM=api:5001

NGINX_SSL_CERT_FILENAME=dify.example.com.pem
NGINX_SSL_CERT_KEY_FILENAME=dify.example.com.key
NGINX_SSL_PROTOCOLS=TLSv1.2 TLSv1.3

NGINX_ENABLE_CERTBOT_CHALLENGE=false
